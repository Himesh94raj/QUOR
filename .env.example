# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SUPABASE_URL: The URL of your Supabase project.
SUPABASE_URL="https://lypahygyocdjplmwluus.supabase.co"

# SUPABASE_KEY: The public/publishable anon key of your Supabase project.
SUPABASE_KEY="sb_publishable_oTS9yxjoBByQ9gtBcHEAYQ_dEUP2gEh"

# SUPABASE_SERVICE_ROLE_KEY: The secret service role key of your Supabase project.
# This key has admin/root privileges and bypasses Row Level Security (RLS) policies.
# Highly secure and must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# VITE_API_URL: The backend API URL for the hosted Railway Express backend.
VITE_API_URL="https://quor-production.up.railway.app"
